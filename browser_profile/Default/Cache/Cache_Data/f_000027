    function salvarDocumentoPreparado(separarDocumentos, importarPecasParaPetsg, itensSelecionadosIntimacaoPendente) {
        const resultado = getItensSelecionados();
        let itensSelecionados = resultado.itensSelecionados;
        const cdDocumento = resultado.cdDocumento;
        if (itensSelecionadosIntimacaoPendente && itensSelecionadosIntimacaoPendente.length > 0) {
            itensSelecionados = itensSelecionados.filter((item, index) => !itensSelecionadosIntimacaoPendente.includes(index));
        }

        $('#popupModalBotaoFechar').off('click').on('click', cancelarProcessamentoDeDocumentos);
        isProcessamentoCancelado = false;
        $('#msgErroIniciarProcessamento').remove();
        $.ajax({
            type: "POST",
            traditional: true,
            url:  $.saj.pasta.usarUrlDocComTarjaEQrcode ? "salvarDocumentoPreparado.do" : "salvarDocumentoPreparadoSemTarjaEQrCode.do",
			data: { "itensPdfSelecionados": itensSelecionados, "cdProcesso":$("#cdProcessoPai").val(), "cdDocumento": cdDocumento, "separarDocumentos": separarDocumentos,
				'acessoPeloPetsg': $.saj.pasta.acessoPeloPetsg},
            success: function (response) {
                if (importarPecasParaPetsg) {
                    if (window.opener === null) {
                        alert(dict['pastadigital.msg.funcionamento.importacao.popup']);
                        return;
                    }

                    window.opener.postMessage(response, '*');
                    window.close();
                    return;
                }

                $('#localizador').val(response);

                var interval = window.setInterval(function () {
                    if (isEnviandoPorEmail) {
                        clearInterval(interval);
                    } else {
                        $.ajax({
                            type: "POST",
                            url: "buscarDocumentoFinalizado.do",
                            data: {
                                localizador: response,
                                cdProcesso: $("#cdProcessoPai").val(),
                                cdDocumento: cdDocumento
                            },
                            success: function (response) {
                                if(!responseContemURLArquivo(response)) {
                                	return;
								}
								if (!isProcessamentoCancelado && !isEnviandoPorEmail) {
                                    $("#urlAcessoArquivo").val(response);
                                    mostrarBotaoBaixarDocumento();
                                    $("#popupGerarDocumentoOpcoes").hide();
                                    $("#popupGerarDocumentoFinalizadoComSucesso").show();
                                    var divPaiModal = $('#popupModalDiv').parent();
                                    divPaiModal.css('height', '175px');
                                    limparEsconderMensagemDeErro();
                                    clearInterval(interval);
                                }
            },
							error: function(xhr) {
							    if(xhr && xhr.status == 401 && xhr.responseText) {
                limparEsconderMensagemDeErro();
                                    var text = xhr.responseText ;
                                    $('#mensagemErro').text(text);
                                    $('#mensagemErro').show();
                                    $('#popupGerarDocumentoOpcoes').hide();
                                    $('#divMsgGerandoDocumento').hide();
                                    $('#btnAguardarProcessamento').hide();
                                    clearInterval(interval);
                                }
            }
        });
    }
				}, 3000);

			},
			error:function(xhr) {
                $('.div-agrupadora').hide();
                $('#btnAguardarProcessamento').hide();
                var msg = dict['pastadigital.msg.nao.foi.possivel.operacao.requisitada'];
                if (xhr.status == 0) {
                    msg = dict['pastadigital.msg.nao.foi.possivel.determinar.servidor.recebeu'];
				}
				else if (xhr.status == 401) {
                    msg = dict['pastadigital.msg.nao.foi.possivel.sessao.expirou'];
                }
                $('.div-agrupadora').after($('<div id="msgErroIniciarProcessamento" style="color:red;">'+msg+'</div>'));
			}
		});
	}

    const getItensSelecionados = () => {
        var itensSelecionados = [];
        var chaves = [], i = 0;
        var mapaDocumentosSelecionados = $.saj.pasta.obterMapaDocumentosSelecionados();

        for (chaves[i++] in mapaDocumentosSelecionados) {}
        chaves.sort(function (a, b) {
            var aIds = a.split('-')
            var bIds = b.split('-')
            var indicePag = parseInt(aIds[1]) - parseInt(bIds[1]);
            if (indicePag === 0) {
                return parseInt(aIds[0]) - parseInt(bIds[0])
            }
            return indicePag;
        })
        i = 0;
        var cdDocumento;
        for (var chave in chaves) {
            var indiceDoMapaDeDocumento = chaves[chave]
            cdDocumento = indiceDoMapaDeDocumento.split('-')[0];
            itensSelecionados[i++] = mapaDocumentosSelecionados[indiceDoMapaDeDocumento]
        }
        return {itensSelecionados, cdDocumento};
    };

	function responseContemURLArquivo(responseText) {
		return responseText &&  responseText.lastIndexOf('http', 0) === 0;
	}

