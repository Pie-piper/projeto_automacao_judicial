    function enviarPorEmail() {
        limparEsconderMensagemDeErro();
        var expressaoRegularEmail = /^[a-zA-Z0-9][a-zA-Z0-9\._-]+@([a-zA-Z0-9\._-]+\.)[a-zA-Z-0-9]{2}/;

        var cdProcesso = $('input[name=\'cdProcesso\']').val();
        var localizador = $('#localizador').val();
        var emailDigitado = $("#emailUsuario").val();
        var emailAlternativo = $("#emailAlternativo").val();

        if (!emailDigitado) {
            emailDigitado = $("#inputEmail").val();
        }

        if (localizador && localizador.length > 0) {
            if (expressaoRegularEmail.exec(emailDigitado)) {
                $.ajax({
                    type: "POST",
                    traditional: true,
                    url: "enviarDocPorEmail.do",
                    data: {"cdProcesso": cdProcesso, "email": emailDigitado, "emailAlternativo": emailAlternativo, localizador: localizador},
                    success: function (response) {
                        isEnviandoPorEmail = true;
                        $('.btConfirmar').hide();
                        $('.btCancelar').hide();
                        $('.btBaixarDocumento').hide();
                        $('#msgAguarde').hide();
                        $('#popupGerarDocumentoOpcoes').hide();
                        $('#popupGerarDocumentoFinalizadoComSucesso').hide();
                        $('#divMsgGerandoDocumento').hide();
                        $('.blockUI.blockMsg.blockPage').css('height', '130px');

                        $('.btInfoEnvioPorEmail').show();
                        var txtMsg = $('#msgInfoEnvioPorEmailHidden').html().replace('##', emailDigitado);
                        $('#msgInfoEnvioPorEmail').html(txtMsg);
                        $('#msgInfoEnvioPorEmail').show();
                        $('#localizador').val('');
                    },
                    error: function (xhr) {
                        var msg = $('#msgErroAguardeEnvioPorEmail').text();
                        if (xhr && xhr.status == 500 && xhr.responseText) {
                            msg = xhr.responseText;
                        }
                        $('#mensagemErro').text(msg);
                        $('#mensagemErro').show();
                    }
                });
            } else {
                $('#mensagemErro').show();
                $('#mensagemErro').html('<b>Por favor digite um e-mail v\u00E1lido </b>');
                $("#inputEmail").select();
            }
        }
        else {
            $('#mensagemErro').text($('#msgInfoAguardeEnvioPorEmail').text());
            $('#mensagemErro').show();
        }
    }

