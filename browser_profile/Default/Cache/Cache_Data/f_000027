    var validaAoCarregarPagina = function () {
        var numeroAssinaturas = $("#tamanhoLista").val();
        if (numeroAssinaturas === "0") {
            $("#divDocumento").css('top', "20px");
            $("#divAssinaturas").css('display', "none");
