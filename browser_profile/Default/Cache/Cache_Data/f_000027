    /**
     * Ajusta o scroll de forma que o item selecionado (pagina atual)
     * esteja visivel para o usuario
     */
    var posicionaScrollNoItemSelecionado = function () {
        var divScrollJQ = $("#divScroll");
        var divScroll = divScrollJQ[0];

        var paginaInicialJQ = $('.paginaVisivel');
        if (paginaInicialJQ.size() == 0) {
            paginaInicialJQ = $('[paginaInicial=true]');
            if (paginaInicialJQ.size() == 0) return;
        }
        var paginaInicial = paginaInicialJQ[0];

        var position = paginaInicialJQ.position().top - divScrollJQ.position().top + paginaInicial.offsetHeight;
        var areaVisivel = divScroll.offsetHeight;
        while (position >= areaVisivel) {
            divScrollJQ.scrollTop(divScroll.scrollTop + (divScroll.offsetHeight / 3));
            var newPosition = paginaInicialJQ.position().top - divScrollJQ.position().top + paginaInicial.offsetHeight;
            if (position === newPosition) {
                position = areaVisivel - 1;
            } else {
                position = newPosition;
            }
        }
        while (position < 0) {
            var newPosition = divScroll.scrollTop - (divScroll.offsetHeight / 3);
            if (newPosition < 0) {
                divScrollJQ.scrollTop(0);
            } else {
                divScrollJQ.scrollTop(newPosition);
            }
            newPosition = paginaInicialJQ.position().top - divScrollJQ.position().top + paginaInicial.offsetHeight;
            if (position === newPosition) {
                position = 0;
            } else {
                position = newPosition;
            }
        }
        if (position < 20) {
            divScrollJQ.scrollTop(divScroll.scrollTop - (divScroll.offsetHeight / 3));
        }
    };

    const obterListaDocumentosPendenteIntimacoes = function (itensSelecionados) {
        let listaDocumentos = [];
