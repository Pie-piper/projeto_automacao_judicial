    /**
     * Popula os itens selecionados na arvore no campo hidden do form
     */
    function populaItensSelecionados() {

        var itensMarcados = null;

        if (materializar) {
            if ($(':input:checkbox:checked').size() === 0) {
                itensMarcados = $("#raiz a:first-child").filter(".checked");
            } else {
                itensMarcados = $(':input:checkbox:checked');
            }
        } else if ($(':input:checkbox:checked').size() === 0) {
            itensMarcados = $("#raiz a:first-child").filter(".checked");
        } else {
            itensMarcados = $(':input:checkbox:checked');
        }

        var linksParans = $(itensMarcados).siblings('a');

        var parametros = new Array();

        linksParans.each(function (i) {
            var texto = $(this).attr("parametros");
            parametros[i] = texto;
        });

        $("#itensPdfSelecionados").val(parametros);
        return parametros;
    }

