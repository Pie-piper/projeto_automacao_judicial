    /*
    * Redimensiona a página
    */
    function windowResize(regiaoAss) {
        var paddingH = 4;
        if ($.browser.msie) {
            paddingH = 0;
        }
        var regiaoAssinatura = $("#regiaoAssinatura")[0];
        var regiaoAssinaturaOffsetHeight = 0;
        var regiaoAssinaturaClientHeight = 0;
        var campoPaginaAtual = $('#campoPaginaAtual')[0];

        var divOutroFormato = $("#divOutroFormato")[0];

        var divAssinaturaEncolhido = $("#linhaAssinaturasEncolhido")[0];

        var regDivOutroFormatoHeight = 0;
        var regPaginacao = 0;

        if (campoPaginaAtual) {
            regPaginacao = campoPaginaAtual.offsetHeight + 15;
        }

        if (divOutroFormato) {
            regDivOutroFormatoHeight = divOutroFormato.offsetHeight;
        }

        if (regiaoAssinatura) {
            regiaoAssinaturaOffsetHeight = regiaoAssinatura.offsetHeight;
            regiaoAssinaturaClientHeight = regiaoAssinatura.offsetHeight;
        }

        var screenH = $("body")[0].clientHeight - regiaoAssinaturaOffsetHeight - paddingH - regDivOutroFormatoHeight;

        $("#documento")[0].setAttribute("height", screenH);
        var paddingW = 5;
        if ($.browser.msie) {
            paddingW = 2;
        }
        var screenW = $("body")[0].clientWidth - $("#divArvore")[0].offsetWidth - $("#divPastaEncolhida")[0].offsetWidth - paddingW;
        $("#documento")[0].setAttribute("width", screenW);
        if (regiaoAssinatura) {
            regiaoAssinatura.style.width = screenW;
        }
        if (divAssinaturaEncolhido) {
            divAssinaturaEncolhido.style.width = screenW;
        }
        $("#divPastaEncolhida")[0].setAttribute("height", (screenH + regiaoAssinaturaClientHeight) + "px");

        var divScrollHeight = $("body")[0].clientHeight - $("#divBotoes")[0].clientHeight - 135 - regPaginacao;

        var divScrollJQ = $("#divScroll");
        divScrollJQ.css('height', divScrollHeight + "px");

        //$.saj.pasta.posicionaScrollNoItemSelecionado();
    }

    /**
     * Caso o status da assinatura tenha sido setado como inválido, redireciona para uma página de erro.
     */
    function verificaAssinatura(status) {
        var ehValido = (new Boolean($('#assinaturaValida').val()));

        if (!ehValido) {
