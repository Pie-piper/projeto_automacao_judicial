# ================================================
# CONFIGURAÇÃO DE CREDENCIAIS - EXEMPLO
# ================================================
# Copie este arquivo para .env e preencha com suas credenciais
# IMPORTANTE: O arquivo .env NÃO deve ser commitado no repositório!
# ================================================

# Credenciais do TJSP (obrigatório)
LOGIN_TJSP=seu_cpf_aqui
SENHA_TJSP=sua_senha_aqui

# Credenciais de Email para 2FA (necessário para login no TJSP)
EMAIL_USER=seu_email@dominio.com.br
EMAIL_PASS=sua_senha_email

# Chave de Licença (obrigatório)
# Gere uma chave única com: python admin_keygen.py
LICENSE_SECRET_KEY=sua_chave_secreta_aqui

# ================================================
# NOTAS IMPORTANTES:
# ================================================
# 1. Para produção, as credenciais devem ser configuradas
#    externamente via variáveis de ambiente ou arquivo .env
#
# 2. O arquivo .env deve estar no MESMO diretório do .exe
#    quando o sistema for distribuído
#
# 3. Para ativar o sistema, use: python admin_keygen.py
#    e gere uma chave de ativação baseada no ID da máquina
# ================================================
